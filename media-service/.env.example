# General
APP_ENV=development

# HTTP
HTTP_PORT=4200
HTTP_HOST=localhost:4200

# GRPC
GRPC_PORT=50059
GRPC_HOST=localhost

# AWS S3 Storage
S3_BUCKET=your-s3-bucket-name
S3_REGION=eu-north-1
S3_ENDPOINT=https://s3.eu-north-1.amazonaws.com
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_PUBLIC_URL=https://your-bucket.s3.eu-north-1.amazonaws.com

# Logging
LOG_LEVEL=info